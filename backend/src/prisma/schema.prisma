datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  name     String
  password String
  respostaSeguranca String
  posts    Post[]
}

model Post {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  title   String
  content String
  userId  String @db.ObjectId
  user    User   @relation(fields: [userId], references: [id])
}